    "functions": [
      {
        "name": "PercentOfTotal",
        "description": "Returns Amount as a percentage of its total when Filter is removed, rounded to DecimalPlaces.",
        "expression": "( Amount: SCALAR DECIMAL VAL, Filter: TABLEREF, DecimalPlaces: INT64 = 2 ) => \r\nROUND (\r\n    DIVIDE ( Amount, CALCULATE ( Amount, REMOVEFILTERS ( Filter ) ) ) * 100,\r\n    DecimalPlaces\r\n)",
