      {
        "name": "Holidays",
        "isHidden": true,
        "lineageTag": "",
        "dataCategory": "Time",
        "columns": [
          {
            "type": "calculatedTableColumn",
            "name": "Holiday Date",
            "dataType": "dateTime",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "isHidden": true,
            "sourceColumn": "[Holiday Date]",
            "formatString": "mm/dd/yyyy",
            "lineageTag": "",
            "summarizeBy": "none"
          },
          {
            "type": "calculatedTableColumn",
            "name": "Holiday Name",
            "dataType": "string",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "isHidden": true,
            "sourceColumn": "[Holiday Name]",
