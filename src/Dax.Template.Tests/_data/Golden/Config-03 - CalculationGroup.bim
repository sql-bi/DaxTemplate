            "sourceColumn": "Quantity"
          }
        ],
        "partitions": [
          {
            "name": "Sales",
            "source": {
              "type": "calculated",
              "expression": "{ (DATE(2020,1,1), 1) }"
            }
          }
        ],
        "measures": [
          {
            "name": "Sales Amount",
            "expression": "SUM(Sales[Quantity])"
          },
          {
            "name": "Total Cost",
            "expression": "SUM(Sales[Quantity])"
          },
          {
            "name": "Margin",
            "expression": "[Sales Amount] - [Total Cost]"
          },
          {
            "name": "Margin %",
            "expression": "DIVIDE([Margin], [Sales Amount])"
          }
        ]
      },
      {
        "name": "Orders",
