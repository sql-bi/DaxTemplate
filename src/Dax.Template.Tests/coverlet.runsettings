<?xml version="1.0" encoding="utf-8"?>
<!--
  Coverage configuration for the offline `Dax.Template.Tests` suite (coverlet's "XPlat Code Coverage"
  data collector, which ships via the coverlet.collector NuGet package already referenced by the test
  project). Scope: Phase M / Stage 0 / P0-b coverage baseline (see .claude/SESSION_HANDOFF.md).

  See docs/design/coverage.md for the exact `dotnet test` invocation that applies this file and for
  feeding the resulting Cobertura XML into ReportGenerator for a human-readable summary.
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>

          <!--
            Include ONLY the shipped core library. This is the metric the 80%/90% thresholds (locked
            decision #5 in SESSION_HANDOFF.md) are measured against. Dax.Template.TestUI (WinForms
            manual harness, not part of the automated test run) and the test assembly itself are
            excluded by construction — Include is an allow-list, so nothing else can leak in even if
            it later becomes reachable from the test process (e.g. a future test project reference).
          -->
          <Include>[Dax.Template]*</Include>
          <Exclude>[Dax.Template.Tests]*,[Dax.Template.TestUI]*,[xunit.*]*</Exclude>

          <!--
            Members/types tagged with these attributes are excluded from the coverage % so it reflects
            reachable code. [ExcludeFromCodeCoverage] (System.Diagnostics.CodeAnalysis) is coverlet's
            standard convention and is intentionally listed here even though coverlet also honors it by
            default — this documents it as the sanctioned mechanism for Stage 2 attribute application
            (generated/trivial members: DTO/ToString/Reset boilerplate; live-server-only branches).
            No library source is annotated yet — see .claude/SESSION_HANDOFF.md Stage 0 P0-b task note
            ("do NOT edit library source ... attribute application is Stage 2").
          -->
          <ExcludeByAttribute>ExcludeFromCodeCoverage,CompilerGeneratedAttribute,GeneratedCodeAttribute,DebuggerNonUserCodeAttribute</ExcludeByAttribute>

          <!-- Auto-generated backing members (e.g. record/property internals) never carry real logic. -->
          <SkipAutoProps>true</SkipAutoProps>

          <!-- Deterministic paths so CI and local runs produce comparable reports. -->
          <UseSourceLink>false</UseSourceLink>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
